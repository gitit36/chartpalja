# Python one-off script (optional; default: python3)
# PYTHON_PATH=python3

# AI 운세 해설 (Gemini)
# https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY="your-gemini-api-key"

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:port/dbname"

# Session encryption (min 32 chars)
SESSION_SECRET="your-session-secret-min-32-chars-long"

# Kakao OAuth
KAKAO_CLIENT_ID="your-kakao-rest-api-key"
KAKAO_REDIRECT_URI="http://localhost:3000/api/auth/kakao/callback"
KAKAO_CLIENT_SECRET="your-kakao-client-secret"

# Kakao JavaScript SDK (카카오톡 공유 등)
# 카카오 개발자 콘솔 > 앱 설정 > 앱 키 > JavaScript 키
NEXT_PUBLIC_KAKAO_JS_KEY="your-kakao-javascript-key"

# PortOne V2 (국내 결제)
# Store ID / Channel Key는 브라우저 결제창 호출에 사용됩니다.
# Railway/Vercel에서는 런타임 env 또는 빌드 env 둘 다 설정해 두는 것을 권장합니다.
PORTONE_V2_API_SECRET="your-portone-v2-api-secret"
PORTONE_STORE_ID="your-portone-store-id"
PORTONE_CHANNEL_KEY_KAKAOPAY="your-portone-kakaopay-channel-key"
PORTONE_CHANNEL_KEY_TOSSPAY="your-portone-tosspay-channel-key"
PORTONE_CHANNEL_KEY_CARD="your-portone-card-channel-key"
NEXT_PUBLIC_PORTONE_STORE_ID="your-portone-store-id"
NEXT_PUBLIC_PORTONE_CHANNEL_KEY_KAKAOPAY="your-portone-kakaopay-channel-key"
NEXT_PUBLIC_PORTONE_CHANNEL_KEY_TOSSPAY="your-portone-tosspay-channel-key"
NEXT_PUBLIC_PORTONE_CHANNEL_KEY_CARD="your-portone-card-channel-key"

# KakaoPay (미구현 — 향후 결제 도입 시)
# KAKAOPAY_CID="TC0ONETIME"
# KAKAOPAY_ADMIN_KEY="your-kakaopay-admin-key"
