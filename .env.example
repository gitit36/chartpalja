# Python one-off script (optional; default: python3)
# PYTHON_PATH=python3

# AI 운세 해설 (Gemini)
# https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY="your-gemini-api-key"

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:port/dbname"

# Session encryption (min 32 chars)
SESSION_SECRET="your-session-secret-min-32-chars-long"

# PG 심사용 테스트 로그인 (/app/test-login)
# 기본 활성화. 운영에서 끄려면 TEST_LOGIN_ENABLED=0. 자격증명 미설정 시 testid00! / testpw00! 사용.
TEST_LOGIN_ENABLED="1"
TEST_LOGIN_ID="testid00!"
TEST_LOGIN_PASSWORD="testpw00!"

# Kakao OAuth
KAKAO_CLIENT_ID="your-kakao-rest-api-key"
KAKAO_REDIRECT_URI="http://localhost:3000/api/auth/kakao/callback"
KAKAO_CLIENT_SECRET="your-kakao-client-secret"

# Kakao JavaScript SDK (카카오톡 공유 등)
# 카카오 개발자 콘솔 > 앱 설정 > 앱 키 > JavaScript 키
NEXT_PUBLIC_KAKAO_JS_KEY="your-kakao-javascript-key"

# ─── PortOne V2 (국내 결제) ────────────────────────────
# 운영/테스트 모드를 명시적으로 토글합니다.
# - test : 포트원 콘솔의 "테스트 채널" 사용 (실제 결제 X)
# - live : 포트원 콘솔의 "실연동 채널" 사용 (실제 결제 O)
PAYMENT_MODE="test"

# 공통 - 상점 ID (브라우저 결제창 호출)
PORTONE_STORE_ID="your-portone-store-id"
NEXT_PUBLIC_PORTONE_STORE_ID="your-portone-store-id"

# ── 테스트 모드 키 ───────────────────────────────────
# 카카오페이/토스페이/카드/계좌이체 각각의 콘솔 채널 키를 입력하세요.
# 한 PG 채널(예: KG이니시스 결제창일반, 토스페이먼츠 신모듈)로 카드+계좌이체를
# 모두 처리한다면 CARD/TRANSFER 두 변수에 같은 채널 키를 넣으면 됩니다.
PORTONE_V2_API_SECRET_TEST="your-portone-v2-test-api-secret"
PORTONE_V2_WEBHOOK_SECRET_TEST="whsec_test_..."
PORTONE_CHANNEL_KEY_KAKAOPAY_TEST="your-test-kakaopay-channel-key"
PORTONE_CHANNEL_KEY_TOSSPAY_TEST="your-test-tosspay-channel-key"
PORTONE_CHANNEL_KEY_CARD_TEST="your-test-card-channel-key"
PORTONE_CHANNEL_KEY_TRANSFER_TEST="your-test-transfer-channel-key"
PORTONE_CHANNEL_KEY_OVERSEAS_TEST="your-test-overseas-channel-key"
NEXT_PUBLIC_PORTONE_CHANNEL_KEY_KAKAOPAY_TEST="your-test-kakaopay-channel-key"
NEXT_PUBLIC_PORTONE_CHANNEL_KEY_TOSSPAY_TEST="your-test-tosspay-channel-key"
NEXT_PUBLIC_PORTONE_CHANNEL_KEY_CARD_TEST="your-test-card-channel-key"
NEXT_PUBLIC_PORTONE_CHANNEL_KEY_TRANSFER_TEST="your-test-transfer-channel-key"
NEXT_PUBLIC_PORTONE_CHANNEL_KEY_OVERSEAS_TEST="your-test-overseas-channel-key"

# ── 실연동 모드 키 ───────────────────────────────────
PORTONE_V2_API_SECRET_LIVE="your-portone-v2-live-api-secret"
PORTONE_V2_WEBHOOK_SECRET_LIVE="whsec_live_..."
PORTONE_CHANNEL_KEY_KAKAOPAY_LIVE="your-live-kakaopay-channel-key"
PORTONE_CHANNEL_KEY_TOSSPAY_LIVE="your-live-tosspay-channel-key"
PORTONE_CHANNEL_KEY_CARD_LIVE="your-live-card-channel-key"
PORTONE_CHANNEL_KEY_TRANSFER_LIVE="your-live-transfer-channel-key"
PORTONE_CHANNEL_KEY_OVERSEAS_LIVE="your-live-overseas-channel-key"
NEXT_PUBLIC_PORTONE_CHANNEL_KEY_KAKAOPAY_LIVE="your-live-kakaopay-channel-key"
NEXT_PUBLIC_PORTONE_CHANNEL_KEY_TOSSPAY_LIVE="your-live-tosspay-channel-key"
NEXT_PUBLIC_PORTONE_CHANNEL_KEY_CARD_LIVE="your-live-card-channel-key"
NEXT_PUBLIC_PORTONE_CHANNEL_KEY_TRANSFER_LIVE="your-live-transfer-channel-key"
NEXT_PUBLIC_PORTONE_CHANNEL_KEY_OVERSEAS_LIVE="your-live-overseas-channel-key"

# 클라이언트(브라우저)에서 어떤 모드인지 알기 위한 미러 변수
NEXT_PUBLIC_PAYMENT_MODE="test"

# 라이브(live) 모드에서 "활성화"로 노출할 결제수단 화이트리스트 (쉼표 구분).
# - test/mock 모드에서는 이 값과 무관하게 모든 수단이 활성화됩니다(심사·QA용).
# - 미설정 시 기본값은 코드의 LIVE_ACTIVE_METHODS(현재 'kakaopay')를 사용합니다.
# - PG 심사 통과 시 코드 수정 없이 여기에 키를 추가하세요.
#   허용값: kakaopay, tosspay, card, transfer, overseas
NEXT_PUBLIC_ACTIVE_PAYMENT_METHODS="kakaopay"

# PG 심사 전 개발용 Mock 결제 (실제 PG 호출 없이 즉시 성공 처리).
# - "true": Mock 결제(개발용). 이때도 결제수단 선택 화면은 전 수단 활성.
# - 그 외/미설정: 실제 PG(PortOne) 결제.
NEXT_PUBLIC_PAYMENT_MOCK="false"

# ─── Paddle (해외 결제, 선택) ──────────────────────
# 현재 결제수단 UI에는 Paddle이 노출되지 않으며(휴면), 실제 사용할 때만 채우세요.
# NEXT_PUBLIC_PADDLE_ENV: sandbox | production
PADDLE_API_KEY="your-paddle-api-key"
PADDLE_WEBHOOK_SECRET="your-paddle-webhook-secret"
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN="your-paddle-client-token"
NEXT_PUBLIC_PADDLE_ENV="sandbox"

# ─── 알림 이메일 (Resend HTTP API, 권장) ───────────
# Railway 등 아웃바운드 SMTP(465/587)를 차단하는 환경에서는 SMTP 대신 이걸 쓰세요.
# RESEND_API_KEY 가 설정되면 sendAlertEmail 이 SMTP 보다 먼저 HTTP(443)로 발송합니다.
# 1) https://resend.com 가입 → API Keys 에서 키 발급
# 2) (선택) 도메인 인증(Domains) 후 RESEND_FROM 을 자기 도메인 발신자로 설정
#    미인증 시 onboarding@resend.dev 로 발송되며, Resend 계정 소유 이메일로만 수신 가능.
# RESEND_API_KEY="re_xxxxxxxx"
# RESEND_FROM="차트팔자 알림 <alerts@chartpalja.com>"

# ─── 결제 알림 (이메일) ────────────────────────────
# Naver SMTP 예시. 다른 SMTP를 쓰려면 호스트/포트만 바꾸면 됩니다.
# Naver: 메일 설정 > POP3/IMAP 설정 > "IMAP/SMTP 사용함" + 2단계 인증 사용 시 "애플리케이션 비밀번호" 발급
# Naver SMTP: Railway 등 클라우드에선 587/STARTTLS 권장 (465 outbound 차단 사례 다수)
# 465 SSL/TLS:  SMTP_PORT=465 / SMTP_SECURE=true
# 587 STARTTLS: SMTP_PORT=587 / SMTP_SECURE=false
SMTP_HOST="smtp.naver.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-naver-id"
SMTP_PASS="your-naver-app-password"
SMTP_FROM="차트팔자 알림 <your-naver-id@naver.com>"
# 디버그 토글: SMTP 연결/SMTP 명령어 로그를 stdout으로 출력 (운영 평소엔 끄기)
# SMTP_DEBUG="true"

# 알림 수신 이메일 (콤마로 여러 명 가능)
ALERT_EMAIL_TO="will36@naver.com"

# 결제 성공/실패/취소 알림을 받을지 토글 (기본: 끄기)
# - "true": 결제 이벤트 알림 발송 (성공/실패/취소)
# - 그 외: 결제 이벤트 알림 미발송. 단, 웹훅 처리 오류는 항상 발송됨.
ALERT_PAYMENT_EVENTS="false"

# ─── Slack 알림 (선택) ─────────────────────────────
# 켜고 싶을 때만 입력. 비워두면 자동 스킵됩니다.
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=""

