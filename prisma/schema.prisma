generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionStatus {
  DRAFT
  SAJU_READY
  PAID_UNLOCKED
  GEMINI_READY
}

model User {
  id          String   @id @default(cuid())
  kakaoId     String   @unique
  email       String?
  nickname    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sessions    AnalysisSession[]
  orders      Order[]
  paymentOrders PaymentOrder[]
  sajuEntries SajuEntry[]
  balance     UserBalance?
  ledger      EntitlementLedger[]
}

model SajuEntry {
  id             String   @id @default(cuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
  guestId        String?
  name           String
  gender         String
  birthDate      String
  birthTime      String?
  timeUnknown    Boolean  @default(false)
  isLunar        Boolean  @default(false)
  isLeapMonth    Boolean  @default(false)
  job            String?
  dayElement     String?
  sajuReportJson Json?
  fortuneJson    Json?
  fortuneJsonB   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@index([userId])
  @@index([guestId])
}

model AnalysisSession {
  id            String        @id @default(cuid())
  userId        String?
  user          User?         @relation(fields: [userId], references: [id])
  status        SessionStatus @default(DRAFT)
  inputRedacted Json?
  sajuReportJson Json?
  geminiJson    Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]
}

model Order {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  sessionId  String
  session    AnalysisSession @relation(fields: [sessionId], references: [id])
  provider   String
  itemCode   String
  amount     Int
  currency   String   @default("KRW")
  status     String   @default("READY")
  tid        String?  @unique
  approvedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@index([userId, status])
  @@index([sessionId, status])
}

// ─── Payment System v2 ───────────────────────────

model PaymentOrder {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  productCode     String
  productType     String
  quantity        Int
  amount          Int
  currency        String    @default("KRW")
  status          String    @default("pending")
  paymentMethod   String?
  provider        String?
  providerTxId    String?   @unique
  rawPayload      Json?
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  ledgerEntries   EntitlementLedger[]
  @@index([userId])
  @@index([status])
}

model UserBalance {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  chartCredits   Int      @default(0)
  periodCredits  Int      @default(3)
  updatedAt      DateTime @updatedAt
}

model EntitlementLedger {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  orderId     String?
  order       PaymentOrder? @relation(fields: [orderId], references: [id])
  creditType  String
  delta       Int
  reason      String
  createdAt   DateTime      @default(now())
  @@index([userId])
  @@index([orderId])
}

// 용신/희신/기신 LLM 판별 캐시 — 동일 4주 조합은 영구 재사용
model YongshinCache {
  id            String   @id @default(cuid())
  fourPillars   String   @unique  // "辛巳_壬辰_乙巳_癸未" 형태
  yongshinElem  String             // 용신 오행: "水"
  heeshinElems  String[]           // 희신 오행: ["木"]
  gishinElems   String[]           // 기신 오행: ["火","土"]
  gushinElems   String[]           // 구신 오행: []
  reasoning     String?            // LLM 판별 근거
  model         String             // 사용 모델: "gemini-2.5-flash"
  createdAt     DateTime @default(now())
}
