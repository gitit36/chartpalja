generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionStatus {
  DRAFT
  SAJU_READY
  PAID_UNLOCKED
  GEMINI_READY
}

model User {
  id          String   @id @default(cuid())
  kakaoId     String   @unique
  email       String?
  nickname    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sessions    AnalysisSession[]
  orders      Order[]
  paymentOrders PaymentOrder[]
  sajuEntries SajuEntry[]
  balance     UserBalance?
  ledger      EntitlementLedger[]
}

model SajuEntry {
  id             String   @id @default(cuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
  guestId        String?
  name           String
  gender         String
  birthDate      String
  birthTime      String?
  timeUnknown    Boolean  @default(false)
  isLunar        Boolean  @default(false)
  isLeapMonth    Boolean  @default(false)
  job            String?
  dayElement     String?
  isRepresentative Boolean @default(false)
  /// 공유 링크 공개 동의 플래그. true 면 비로그인 수신자도 /share/[id] 로 결과를 볼 수 있다.
  isShared       Boolean  @default(false)
  sajuReportJson Json?
  fortuneJson    Json?
  fortuneJsonB   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  dailyFortunes  DailyFortune[]
  @@index([userId])
  @@index([guestId])
}

// 일별 운세 점수 캐시 — (entry, date)별로 결정적이라 한 번 계산하면 영구 재사용.
// 점수는 순수 엔진 산출물(LLM 비용 0). 출생정보 수정 시 해당 entry 캐시는 삭제한다.
model DailyFortune {
  id             String    @id @default(cuid())
  entryId        String
  entry          SajuEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  date           String                       // "YYYY-MM-DD" (KST 기준)
  score          Int
  grade          String
  seasonTag      String?
  seasonEmoji    String?
  /// 6대 생활 도메인 운세 점수 (0~100). { 연애, 대인, 재물, 학업, 직업, 건강 }
  domainsJson    Json?
  createdAt      DateTime  @default(now())
  @@unique([entryId, date])
  @@index([entryId])
}

model AnalysisSession {
  id            String        @id @default(cuid())
  userId        String?
  user          User?         @relation(fields: [userId], references: [id])
  status        SessionStatus @default(DRAFT)
  inputRedacted Json?
  sajuReportJson Json?
  geminiJson    Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]
}

model Order {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  sessionId  String
  session    AnalysisSession @relation(fields: [sessionId], references: [id])
  provider   String
  itemCode   String
  amount     Int
  currency   String   @default("KRW")
  status     String   @default("READY")
  tid        String?  @unique
  approvedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@index([userId, status])
  @@index([sessionId, status])
}

// ─── Payment System v2 ───────────────────────────

model PaymentOrder {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  productCode     String                       // 주 상품 코드 (보통 chart_*)
  productType     String                       // 주 상품 타입 (chart | period)
  quantity        Int                          // 주 상품 수량
  /// 묶음 결제 시 추가로 포함된 부 상품들. JSON 배열: [{code, type, quantity, amount, currency}]
  /// 단일 상품 결제면 null/[].
  extraItems      Json?
  amount          Int                          // 총 결제 금액 (KRW 또는 USD cents)
  currency        String    @default("KRW")
  status          String    @default("pending")
  paymentMethod   String?
  provider        String?
  providerTxId    String?   @unique
  rawPayload      Json?
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  ledgerEntries   EntitlementLedger[]
  @@index([userId])
  @@index([status])
}

model UserBalance {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  /// 단일 통화 "주(株)" — 구간1 / 운세5 / 궁합5 차감
  ju        Int      @default(3)
  updatedAt DateTime @updatedAt
}

model EntitlementLedger {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  orderId     String?
  order       PaymentOrder? @relation(fields: [orderId], references: [id])
  creditType  String
  delta       Int
  reason      String
  createdAt   DateTime      @default(now())
  @@index([userId])
  @@index([orderId])
}

// 용신/희신/기신 LLM 판별 캐시 — 동일 4주 조합은 영구 재사용
model YongshinCache {
  id            String   @id @default(cuid())
  fourPillars   String   @unique  // "辛巳_壬辰_乙巳_癸未" 형태
  yongshinElem  String             // 용신 오행: "水"
  heeshinElems  String[]           // 희신 오행: ["木"]
  gishinElems   String[]           // 기신 오행: ["火","土"]
  gushinElems   String[]           // 구신 오행: []
  reasoning     String?            // LLM 판별 근거
  model         String             // 사용 모델: "gemini-2.5-flash"
  createdAt     DateTime @default(now())
}

model CompatInvite {
  id             String   @id @default(cuid())
  token          String   @unique
  inviterUserId  String
  inviterEntryId String
  inviteeUserId  String?
  inviteeEntryId String?
  status         String   @default("pending")
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  @@index([inviterUserId])
  @@index([token])
}

model CompatLink {
  id          String   @id @default(cuid())
  userId      String
  entryId     String
  peerUserId  String
  peerEntryId String
  source      String   @default("invite")
  createdAt   DateTime @default(now())
  @@unique([userId, entryId, peerEntryId])
  @@index([userId])
  @@index([peerEntryId])
}
